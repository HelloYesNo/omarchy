#!/bin/bash

# Show a fuzzy-finder TUI for picking new Flatpak applications to install.

# Ensure flatpak is installed
if ! command -v flatpak &>/dev/null; then
  echo "Flatpak is not installed. Installing..." >&2
  omarchy-pkg-add flatpak
  if ! command -v flatpak &>/dev/null; then
    echo "Failed to install flatpak." >&2
    exit 1
  fi
fi

# Ensure flathub remote is added
if ! flatpak remote-list | grep -q flathub; then
  echo "Flathub remote not found. Adding..." >&2
  flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
fi

fzf_args=(
  --multi
  --preview 'flatpak remote-info flathub {1}'
  --preview-label='alt-p: toggle description, alt-j/k: scroll, tab: multi-select'
  --preview-label-pos='bottom'
  --preview-window 'down:65%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --color 'pointer:green,marker:green'
)

# List available applications from flathub
pkg_names=$(flatpak remote-ls flathub --columns=application | fzf "${fzf_args[@]}")

if [[ -n $pkg_names ]]; then
  source omarchy-sudo-keepalive

  # Convert newline-separated selections to space-separated
  echo "$pkg_names" | tr '\n' ' ' | xargs flatpak install -y flathub
  omarchy-show-done
fi