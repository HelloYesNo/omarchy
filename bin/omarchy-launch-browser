#!/bin/bash

# Launch the default browser as determined by xdg-settings.
# Automatically converts --private into the correct flag for the given browser.

default_browser=$(xdg-settings get default-web-browser)

# Try to find the desktop file in common locations
desktop_paths=(
  ~/.local/share/applications
  ~/.nix-profile/share/applications
  /usr/share/applications
  /var/lib/flatpak/exports/share/applications
  ~/.local/share/flatpak/exports/share/applications
)

browser_exec=
app_id=
for path in "${desktop_paths[@]}"; do
  desktop_file="$path/$default_browser"
  if [[ -f $desktop_file ]]; then
    # Extract the Exec line, remove placeholders, and trim
    exec_line=$(grep -m1 '^Exec=' "$desktop_file" | sed 's/^Exec=//')
    exec_line=$(echo "$exec_line" | sed 's/%[a-zA-Z]//g; s/@@[^ ]*//g; s/  */ /g; s/^ *//; s/ *$//')
    if [[ -n $exec_line ]]; then
      browser_exec="$exec_line"
      # Try to extract app_id for flatpak commands
      if [[ $exec_line == *flatpak\ run* ]]; then
        # Extract the last argument (should be the app ID)
        app_id=$(echo "$exec_line" | awk '{print $NF}')
      fi
      break
    fi
  fi
done

# If still empty, try to construct a flatpak command from the desktop file ID
if [[ -z $browser_exec && $default_browser == *.desktop ]]; then
    app_id="${default_browser%.desktop}"
    if flatpak info "$app_id" &>/dev/null; then
        browser_exec="flatpak run $app_id"
    fi
fi

if [[ -z $browser_exec ]]; then
    echo "Error: Could not determine browser command for $default_browser" >&2
    exit 1
fi

# Split the command into arguments for uwsm-app
IFS=' ' read -r -a cmd_array <<< "$browser_exec"

# Determine the appropriate private flag
private_flag="--incognito"  # default for Chromium-based browsers
if [[ ${cmd_array[0]} == *flatpak ]] && [[ -n $app_id ]]; then
    # Flatpak app: check app ID
    case $app_id in
      *[Ff]irefox*|*[Mm]ozilla*|*[Ff]ennec*)
        private_flag="--private-window"
        ;;
      *edge*)
        private_flag="--inprivate"
        ;;
      *)
        # Assume Chromium-based (Brave, Chrome, Chromium, Zen, etc.)
        private_flag="--incognito"
        ;;
    esac
elif "${cmd_array[@]}" --help 2>&1 | grep -q MOZ_LOG; then
    private_flag="--private-window"
elif [[ ${cmd_array[0]} == *edge ]]; then
    private_flag="--inprivate"
fi

exec setsid uwsm-app -- "${cmd_array[@]}" "${@/--private/$private_flag}"